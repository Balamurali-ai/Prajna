# ====================================================
# Frontend Environment Variables
# ====================================================
# Copy to .env and fill in your secrets.

# ====================================================
# API
# ====================================================
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_BASE_URL=ws://localhost:8000

# ====================================================
# Supabase
# ====================================================
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ====================================================
# Mapbox
# ====================================================
VITE_MAPBOX_PUBLIC_TOKEN=pk.your-mapbox-public-token
VITE_MAPBOX_STYLE=dark-v11
VITE_DEFAULT_MAP_CENTER=78.9629,20.5937
VITE_DEFAULT_MAP_ZOOM=4

# ====================================================
# App
# ====================================================
VITE_APP_NAME=Crime Intelligence Platform
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=development

# ====================================================
# Feature flags
# ====================================================
VITE_FEATURE_WEBSOCKETS=true
VITE_FEATURE_PDF_EXPORT=true
VITE_FEATURE_GEOJSON_EXPORT=true
