# ====================================================
# Backend Environment Variables
# ====================================================
# Copy this file to .env and fill in your secrets.
# NEVER commit real .env files.

# ====================================================
# Application
# ====================================================
APP_NAME=crime-intelligence-backend
APP_ENV=development
APP_VERSION=1.0.0
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO
APP_TIMEZONE=UTC

# ====================================================
# CORS
# ====================================================
CORS_ORIGINS=["http://localhost:5173","http://localhost:5174","http://localhost:3000"]
CORS_ALLOW_CREDENTIALS=true

# ====================================================
# Supabase (Database + Auth)
# ====================================================
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
DATABASE_URL=
DATABASE_POOL_SIZE=10

# ====================================================
# Redis
# ====================================================
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
CACHE_TTL_SECONDS=300

# ====================================================
# Auth & Security
# ====================================================
JWT_ALGORITHM=HS256
JWT_AUDIENCE=authenticated
ACCESS_TOKEN_EXPIRE_MINUTES=60
RATE_LIMIT_PER_MINUTE=100

# ====================================================
# ML Artifacts (Read-Only)
# ====================================================
ML_ARTIFACTS_PATH=./app/ml_artifacts
ML_CACHE_REFRESH_SECONDS=900
ML_HOTSPOT_TOP_N=20

# ====================================================
# Observability
# ====================================================
SENTRY_DSN=
LOG_FORMAT=text
